# ORBIT Production Environment
# Vultr Seoul VPS에 배포 시 이 파일을 .env로 복사 후 값 입력

# DB (강한 비밀번호로 변경!)
ORBIT_DB_PASSWORD=your-strong-db-password-here

# 인증 (반드시 변경!)
ORBIT_ADMIN_USERNAME=jay
ORBIT_ADMIN_PASSWORD=your-strong-password-here
ORBIT_SECRET_KEY=your-random-secret-key-64chars

# 포트 (Coolify 리버스 프록시 뒤에서는 8000 그대로)
ORBIT_PORT=8000

# GitHub (선택)
ORBIT_GITHUB_TOKEN=ghp_xxxxx

# OpenAI (선택)
ORBIT_OPENAI_API_KEY=sk-xxxxx

# 인프라 관리 대상 DB들 (JSON)
ORBIT_MANAGED_DATABASES=[{"alias":"orbit","url":"postgresql://orbit:your-strong-db-password-here@db:5432/orbit","description":"ORBIT"}]

# 인프라 관리 대상 서버들 (JSON)
ORBIT_MANAGED_SERVERS=[{"name":"vultr-seoul","host":"your-vultr-ip","type":"vultr","description":"ORBIT VPS Seoul"}]
